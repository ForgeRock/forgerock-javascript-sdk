{
  "targetDefaults": {
    "e2e": {
      "dependsOn": ["plugins-wait-for-api:build"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "build-interceptor": {
      "cache": true
    },
    "@nx/vite:test": {
      "dependsOn": ["^test"],
      "inputs": ["default", "^default"],
      "cache": true
    },
    "@nx/eslint:lint": {
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json"],
      "cache": true
    },
    "@nx/vite:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"]
    }
  },
  "targetDependencies": {
    "test": [
      {
        "target": "test",
        "projects": "dependencies"
      }
    ],
    "build": [
      {
        "target": "build",
        "projects": "dependencies"
      }
    ],
    "prepare": [
      {
        "target": "prepare",
        "projects": "dependencies"
      }
    ],
    "package": [
      {
        "target": "package",
        "projects": "dependencies"
      }
    ]
  },
  "workspaceLayout": {
    "appsDir": "",
    "libsDir": ""
  },
  "affected": {
    "defaultBase": "develop"
  },
  "generators": {
    "@nx/web:application": {
      "style": "css",
      "linter": "eslint",
      "unitTestRunner": "jest",
      "e2eTestRunner": "none"
    },
    "@nx/web:library": {
      "style": "css",
      "linter": "eslint",
      "unitTestRunner": "jest"
    }
  },
  "release": {
    "projects": ["packages/*"],
    "releaseTagPattern": "{version}",
    "changelog": {
      "projectChangelogs": true
    }
  },
  "defaultProject": "javascript-sdk",
  "useDaemonProcess": true,
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json"
    ]
  }
}
