{
  "name": "davinci-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/davinci-client/src",
  "projectType": "library",
  "tags": ["scope:package"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/davinci-client/dist",
        "main": "packages/davinci-client/src/index.ts",
        "tsConfig": "packages/davinci-client/tsconfig.lib.json",
        "generateExportsField": false,
        "assets": []
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/packages/davinci-client"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/davinci-client/**/*.ts"],
        "fix": true
      }
    }
  }
}
