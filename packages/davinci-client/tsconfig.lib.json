{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "moduleResolution": "Bundler",
    "module": "ES2020",
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/mock-data/**/*"
  ]
}
