{
  "name": "token-vault-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "e2e/token-vault-app/src",
  "tags": ["scope:app"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "dependsOn": ["remove-extra-folder"],
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/e2e/token-vault-app"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "remove-extra-folder": {
      "executor": "@nrwl/workspace:run-commands",
      "dependsOn": ["build-interceptor"],
      "options": {
        "command": "rm -rf e2e/token-vault-app/e2e"
      }
    },
    "build-interceptor": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/e2e/token-vault-app",
        "configFile": "e2e/token-vault-app/vite.interceptor.config.ts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "token-vault-app:build",
        "host": "localhost",
        "port": 5823
      },
      "configurations": {
        "development": {
          "buildTarget": "token-vault-app:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "token-vault-app:build:production",
          "hmr": false
        }
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "token-vault-app:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "token-vault-app:build:development"
        },
        "production": {
          "buildTarget": "token-vault-app:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["e2e/token-vault-app/**/*.ts"]
      }
    }
  }
}
